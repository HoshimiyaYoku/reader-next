# Copy this file to .env.docker before running docker compose.
# Keep secrets out of git.

# Public container port on the host.
READER_PORT=18080

# Optional: pin a version instead of latest, e.g. ghcr.io/maple0517/reader-next:v1.0.6
READER_IMAGE=ghcr.io/maple0517/reader-next:latest

# Reader config.
SECURE=false
SECURE_KEY=
INVITE_CODE=
USER_LIMIT=50
USER_BOOK_LIMIT=2000
LOG_LEVEL=info
REQUEST_TIMEOUT_SECS=15
