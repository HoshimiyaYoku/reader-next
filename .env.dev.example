# Dev-only local server cfg.
SERVER_HOST=0.0.0.0
SERVER_PORT=18080

# Keep dev data isolated from the Docker-backed daily-use instance.
DATABASE_URL=sqlite:dev-storage/reader.db?mode=rwc
STORAGE_DIR=dev-storage
ASSETS_DIR=dev-storage/assets

# Single-port mode still serves the built frontend.
WEB_ROOT=frontend/dist
LOG_LEVEL=info
REQUEST_TIMEOUT_SECS=15

# Optional security settings for dev.
SECURE=false
INVITE_CODE=
USER_LIMIT=50
USER_BOOK_LIMIT=2000
